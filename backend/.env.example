# ============================================================
# MB2 Core — Backend environment variables
# ============================================================
# Copy this file to ".env" for local development and fill in real values.
# In production (Render), set these in the service's Environment settings —
# NEVER commit a real .env file. (.env is gitignored.)

# --- Database (REQUIRED) ---
# PostgreSQL connection string. Locally, point at your own Postgres.
# In production, paste the "Internal Database URL" Render gives you.
DATABASE_URL=postgres://username:password@localhost:5432/mb2core

# SSL: leave unset in production (SSL auto-enables when NODE_ENV=production).
# For a local Postgres without SSL, set this to "disable".
# PGSSL=disable

# --- Auth (REQUIRED in production) ---
# Secret used to sign login tokens (JWT). Generate a long random string, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# --- Runtime ---
# Render sets PORT automatically; this is only for local override.
PORT=5000
# Set to "production" on Render. Enables Postgres SSL.
NODE_ENV=development

# --- Cloudflare R2 (receipt photos) ---
# Set ALL FIVE to store photos in R2 (required for production on Render).
# Leave them unset locally to fall back to disk storage (backend/uploads/).
#   R2_ACCOUNT_ID      = your Cloudflare account ID
#   R2_ACCESS_KEY_ID / R2_SECRET_ACCESS_KEY = an R2 API token's keys
#   R2_BUCKET          = the bucket name (e.g. mb2-receipts)
#   R2_PUBLIC_URL      = public base URL for the bucket (no trailing slash),
#                        e.g. https://pub-xxxxxxxx.r2.dev or a custom domain
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=mb2-receipts
R2_PUBLIC_URL=

# --- Email (Resend) — weekly recap emails ---
# Get an API key at resend.com. Verify a sender (a single address to start, or
# your mb2cares.com domain for best deliverability). Leave RESEND_API_KEY unset
# to keep emails in "dry mode" (logged, not sent).
#   FROM_EMAIL must be a verified sender, in "Name <email>" form.
RESEND_API_KEY=
FROM_EMAIL=MB2 Core <notifications@mb2cares.com>
# Set to "false" to hard-disable all sending even if a key is present:
# EMAIL_ENABLED=true
