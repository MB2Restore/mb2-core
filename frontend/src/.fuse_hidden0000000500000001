.app {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
}

.app-header {
  background: linear-gradient(135deg, #0C1015 0%, #1a1f2e 100%);
  color: white;
  padding: 20px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 12px;
}

.header-user {
  display: flex;
  align-items: center;
  gap: 14px;
}

.user-greeting {
  font-size: 14px;
  color: #ddd;
  display: flex;
  align-items: center;
  gap: 8px;
}

.user-role-pill {
  background: rgba(255, 255, 255, 0.15);
  color: #fff;
  font-size: 11px;
  font-weight: 600;
  padding: 3px 10px;
  border-radius: 12px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.logout-btn {
  background: rgba(255, 255, 255, 0.12);
  color: #fff;
  border: 1px solid rgba(255, 255, 255, 0.25);
  border-radius: 6px;
  padding: 7px 14px;
  font-size: 13px;
  cursor: pointer;
}

.logout-btn:hover {
  background: rgba(255, 255, 255, 0.22);
}

.app-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100vh;
  font-size: 18px;
  color: #666;
}

.current-user-display {
  padding: 11px 14px;
  background: #f0f4ff;
  border: 1px solid #d8e2ff;
  border-radius: 8px;
  font-weight: 600;
  color: #2c3e7a;
}

/* Field-mode: roomier touch targets for phone use */
.field-mode .nav-btn {
  padding: 14px 22px;
  font-size: 16px;
}

.header-content h1 {
  font-size: 28px;
  margin-bottom: 5px;
}

.header-logo {
  height: 40px;
  width: auto;
  display: block;
  margin-bottom: 4px;
}

.subtitle {
  font-size: 14px;
  color: #999;
}

.app-nav {
  display: flex;
  gap: 10px;
  padding: 15px 20px;
  background-color: white;
  border-bottom: 1px solid #e0e0e0;
  flex-wrap: wrap;
}

.nav-btn {
  padding: 10px 20px;
  background-color: #f0f0f0;
  border: 2px solid #ddd;
  border-radius: 6px;
  cursor: pointer;
  font-size: 14px;
  font-weight: 500;
  transition: all 0.3s ease;
}

.nav-btn:hover {
  background-color: #e8e8e8;
  border-color: #0C1015;
}

.nav-btn.active {
  background-color: #0C1015;
  color: white;
  border-color: #0C1015;
}

.message {
  background-color: #4caf50;
  color: white;
  padding: 12px 20px;
  text-align: center;
  font-size: 14px;
  animation: slideDown 0.3s ease;
}

@keyframes slideDown {
  from {
    transform: translateY(-100%);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.app-main {
  flex: 1;
  overflow-y: auto;
  padding: 20px;
  max-width: 1200px;
  margin: 0 auto;
  width: 100%;
}

@media (max-width: 768px) {
  .app-header {
    padding: 15px;
  }

  .header-content h1 {
    font-size: 22px;
  }

  .app-nav {
    padding: 10px;
    gap: 8px;
  }

  .nav-btn {
    padding: 8px 12px;
    font-size: 12px;
  }

  .app-main {
    padding: 10px;
  }
}
